---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isEs = lang === 'es';

const softSkills = isEs
  ? [
      { emoji: '🤝', label: 'Trabajo en Equipo' },
      { emoji: '🧩', label: 'Resolución de Problemas' },
      { emoji: '🗣️', label: 'Comunicación' },
      { emoji: '📋', label: 'Organización' },
      { emoji: '🚀', label: 'Aprendizaje Continuo' },
      { emoji: '🌐', label: 'Adaptabilidad' },
      { emoji: '🎯', label: 'Negociación' },
      { emoji: '✅', label: 'Ética Profesional' },
    ]
  : [
      { emoji: '🤝', label: 'Teamwork' },
      { emoji: '🧩', label: 'Problem Solving' },
      { emoji: '🗣️', label: 'Communication' },
      { emoji: '📋', label: 'Organization' },
      { emoji: '🚀', label: 'Continuous Learning' },
      { emoji: '🌐', label: 'Adaptability' },
      { emoji: '🎯', label: 'Negotiation' },
      { emoji: '✅', label: 'Professional Ethics' },
    ];
---

<section id="skills" class="relative py-20 lg:py-28" aria-label={isEs ? 'Habilidades técnicas y herramientas' : 'Technical skills and tools'} style="content-visibility: auto; contain-intrinsic-size: auto 600px;">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- Section header -->
    <div class="reveal mb-16 lg:mb-24 max-w-2xl">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-0.5 bg-primary-500"></div>
        <span class="text-sm font-semibold tracking-widest uppercase text-primary-500">
          {isEs ? 'Stack técnico' : 'Tech Stack'}
        </span>
      </div>
      <h2 class="text-4xl lg:text-5xl font-black text-slate-900 dark:text-white mb-4">{t('skills.title')}</h2>
      <p class="text-lg text-slate-500 dark:text-slate-400 leading-relaxed">{t('skills.description')}</p>
    </div>

    <!-- Categories -->
    <div class="grid grid-cols-1 gap-0">

      <!-- Cloud & Azure -->
      <div class="skill-row flex flex-col gap-3 lg:flex-row lg:items-start lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-10 mb-10" style="--delay:0ms">
        <div class="lg:w-48 lg:shrink-0 lg:pt-1.5">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">Cloud</span>
        </div>
        <div class="flex flex-wrap gap-3">
          <!-- Devicon -->
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:40ms">
            <i class="devicon-azure-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Microsoft Azure</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:80ms">
            <i class="devicon-azuredevops-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure DevOps / ADO</span>
          </div>
          <!-- Emoji fallback pills -->
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:120ms">
            <span class="text-base leading-none">🖥️</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Virtual Machines</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:160ms">
            <span class="text-base leading-none">⚡</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Functions</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:200ms">
            <span class="text-base leading-none">🌐</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure App Service</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:240ms">
            <span class="text-base leading-none">🗄️</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure SQL Database</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:280ms">
            <span class="text-base leading-none">🔑</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Key Vault</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:320ms">
            <span class="text-base leading-none">📦</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Storage Account</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:360ms">
            <span class="text-base leading-none">🔍</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Resource Graph + KQL</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:400ms">
            <span class="text-base leading-none">📊</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Advisor</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:440ms">
            <span class="text-base leading-none">🚀</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Migrate</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:480ms">
            <span class="text-base leading-none">📋</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Policy</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:520ms">
            <span class="text-base leading-none">🛡️</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">RBAC / Entra ID</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:560ms">
            <span class="text-base leading-none">🔗</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Hub & Spoke Networking</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:600ms">
            <span class="text-base leading-none">🔒</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Private Link / App Gateway</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:640ms">
            <span class="text-base leading-none">📄</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">ARM Templates</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:680ms">
            <span class="text-base leading-none">💰</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">FinOps</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:720ms">
            <span class="text-base leading-none">🛡️</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Zero Trust</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:760ms">
            <i class="devicon-amazonwebservices-plain-wordmark colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Amazon Web Services</span>
          </div>
        </div>
      </div>

      <!-- Automation & IaC -->
      <div class="skill-row flex flex-col gap-3 lg:flex-row lg:items-start lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-10 mb-10" style="--delay:80ms">
        <div class="lg:w-48 lg:shrink-0 lg:pt-1.5">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">
            {isEs ? 'Automatización' : 'Automation'}
          </span>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:40ms">
            <i class="devicon-powershell-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">PowerShell</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:80ms">
            <span class="text-base leading-none font-mono text-xs">{'>'}_</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure CLI</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:120ms">
            <span class="text-base leading-none">📄</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">ARM Templates</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:160ms">
            <span class="text-base leading-none">🔍</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">KQL</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:200ms">
            <i class="devicon-git-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Git</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:240ms">
            <i class="devicon-github-original text-xl w-6 h-6 flex items-center justify-center dark:invert"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">GitHub</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:280ms">
            <i class="devicon-terraform-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Terraform</span>
          </div>
        </div>
      </div>

      <!-- Platform Engineering -->
      <div class="skill-row flex flex-col gap-3 lg:flex-row lg:items-start lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-10 mb-10" style="--delay:120ms">
        <div class="lg:w-48 lg:shrink-0 lg:pt-1.5">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">Platform Engineering</span>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:40ms">
            <i class="devicon-astro-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Astro</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:80ms">
            <i class="devicon-tailwindcss-original colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Tailwind CSS</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:120ms">
            <span class="text-base leading-none">⚡</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure Functions</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:160ms">
            <i class="devicon-typescript-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">TypeScript</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:200ms">
            <i class="devicon-vscode-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">VS Code</span>
          </div>
        </div>
      </div>

      <!-- Soft Skills -->
      <div class="skill-row flex flex-col gap-3 lg:flex-row lg:items-start lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-10 mb-10" style="--delay:160ms">
        <div class="lg:w-48 lg:shrink-0 lg:pt-1.5">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">Soft Skills</span>
        </div>
        <div class="flex flex-wrap gap-3">
          {softSkills.map(({ emoji, label }, i) => (
            <div
              class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200"
              style={`--delay: ${i * 40}ms`}
            >
              <span class="text-base leading-none">{emoji}</span>
              <span class="text-sm font-medium text-slate-700 dark:text-slate-200">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Languages -->
      <div class="skill-row flex flex-col gap-3 lg:flex-row lg:items-start lg:gap-12" style="--delay:200ms">
        <div class="lg:w-48 lg:shrink-0 lg:pt-1.5">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">
            {isEs ? 'Idiomas' : 'Languages'}
          </span>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:40ms">
            <span class="text-base leading-none">🇪🇸</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Español — Nativo</span>
          </div>
          <div class="skill-pill flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200" style="--delay:80ms">
            <span class="text-base leading-none">🇬🇧</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">English — B2</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-24px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .reveal {
    opacity: 0;
  }
  .reveal.animated {
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .skill-row {
    opacity: 0;
  }
  .skill-row.animated {
    animation: slideInLeft 0.5s ease both;
    animation-delay: var(--delay, 0ms);
  }

  .skill-pill {
    opacity: 0;
  }
  .skill-pill.animated {
    animation: fadeUp 0.4s ease both;
    animation-delay: var(--delay, 0ms);
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('#skills .reveal, #skills .skill-row, #skills .skill-pill').forEach((el) => io.observe(el));
</script>
