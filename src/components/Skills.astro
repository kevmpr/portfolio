---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const technicalSkills: { category: string; icon: string; skills: string[]; gradient: string; iconGradient: string }[] = [
  {
    category: 'Cloud & Infrastructure',
    icon: '☁️',
    gradient: 'from-blue-500 to-cyan-500',
    iconGradient: 'from-blue-500 to-cyan-500',
    skills: [
      'Microsoft Azure',
      'AWS',
      'Azure Virtual Machines',
      'VNets & NSG',
      'Azure Migrate',
      'Private Endpoints',
      'DNS',
      'Application Gateway',
    ],
  },
  {
    category: 'Networking & Security',
    icon: '🔒',
    gradient: 'from-violet-500 to-purple-500',
    iconGradient: 'from-violet-500 to-purple-500',
    skills: [
      'Azure Networking',
      'RBAC',
      'Azure Advisor',
      'Azure Resource Graph',
      'FinOps',
    ],
  },
  {
    category: 'Automation & Tools',
    icon: '⚙️',
    gradient: 'from-orange-500 to-amber-500',
    iconGradient: 'from-orange-500 to-amber-500',
    skills: [
      'PowerShell',
      'Docker',
      'Git',
      'Postman',
      'Trello',
      'Azure Pricing Calculator',
    ],
  },
  {
    category: 'Frontend',
    icon: '🎨',
    gradient: 'from-pink-500 to-rose-500',
    iconGradient: 'from-pink-500 to-rose-500',
    skills: [
      'HTML',
      'CSS',
      'Tailwind CSS',
      'JavaScript',
      'TypeScript',
      'Angular',
    ],
  },
  {
    category: 'Backend & Databases',
    icon: '🗄️',
    gradient: 'from-emerald-500 to-green-500',
    iconGradient: 'from-emerald-500 to-green-500',
    skills: [
      'Node.js',
      'Express.js',
      'Java',
      'Spring',
      'PostgreSQL',
      'MySQL',
    ],
  },
  {
    category: 'Azure Services',
    icon: '🔷',
    gradient: 'from-cyan-500 to-blue-500',
    iconGradient: 'from-cyan-500 to-blue-500',
    skills: [
      'Web Apps',
      'App Service Plans',
      'SQL Server',
      'MySQL Flexible Server',
      'Function Apps',
      'API Management',
      'Cloudockit',
    ],
  },
];

const softSkillCategories = [
  {
    categoryKey: 'soft.collab' as const,
    icon: '🤝',
    gradient: 'from-blue-500 to-sky-500',
    iconGradient: 'from-blue-500 to-sky-500',
    skills: [
      { key: 'soft.teamwork' as const,      emoji: '🤝' },
      { key: 'soft.communication' as const, emoji: '💬' },
      { key: 'soft.negotiation' as const,   emoji: '🎯' },
    ],
  },
  {
    categoryKey: 'soft.cognitive' as const,
    icon: '🧠',
    gradient: 'from-emerald-500 to-teal-500',
    iconGradient: 'from-emerald-500 to-teal-500',
    skills: [
      { key: 'soft.critical' as const,      emoji: '🧠' },
      { key: 'soft.adaptability' as const,  emoji: '⚡' },
    ],
  },
  {
    categoryKey: 'soft.organization' as const,
    icon: '📋',
    gradient: 'from-violet-500 to-purple-500',
    iconGradient: 'from-violet-500 to-purple-500',
    skills: [
      { key: 'soft.planning' as const,      emoji: '📋' },
      { key: 'soft.ethics' as const,        emoji: '✅' },
    ],
  },
];

const languageCategory = {
  categoryKey: 'lang.multilingual' as const,
  icon: '🌐',
  gradient: 'from-primary-500 to-accent-500',
  iconGradient: 'from-primary-500 to-accent-500',
  skills: [
    { key: 'lang.spanish' as const, badge: lang === 'en' ? 'Native' : 'Nativo' },
    { key: 'lang.english' as const, badge: 'B2' },
  ],
};
---

<section id="skills" class="relative py-20 lg:py-28" style="content-visibility: auto; contain-intrinsic-size: auto 600px;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent">
          {t('skills.title')}
        </span>
      </h2>
      <!-- Decorative accent line -->
      <div class="flex items-center justify-center gap-3 mt-3">
        <div class="h-px w-16 bg-gradient-to-r from-transparent to-primary-400 dark:to-primary-500"></div>
        <div class="h-[3px] w-12 rounded-full bg-gradient-to-r from-primary-500 to-accent-500"></div>
        <div class="h-px w-16 bg-gradient-to-l from-transparent to-accent-400 dark:to-accent-500"></div>
      </div>
    </div>

    <!-- Technical Skills -->
    <div class="mb-12">
      <h3 class="text-2xl font-bold mb-8 text-center text-slate-700 dark:text-slate-200 reveal">
        {t('skills.technical')}
      </h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {technicalSkills.map((category, i) => (
          <div class="reveal h-full" style={`--reveal-delay: ${i * 100}ms`}>
            <div class="skill-card group bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-xl transition-all duration-300 rounded-2xl overflow-hidden h-full">
              <!-- Gradient top accent strip -->
              <div class={`h-[3px] w-full bg-gradient-to-r ${category.gradient}`}></div>
              <div class="p-5 h-full hover:-translate-y-1 transition-transform duration-300">
                <!-- Card header -->
                <div class="flex items-center gap-3 mb-4 pb-3 border-b border-slate-100 dark:border-slate-700/60">
                  <div class={`w-11 h-11 rounded-xl bg-gradient-to-br ${category.iconGradient} flex items-center justify-center text-xl flex-shrink-0`}>
                    {category.icon}
                  </div>
                  <h4 class="font-bold text-base text-slate-800 dark:text-slate-100">{category.category}</h4>
                  <span class="ml-auto text-xs font-medium text-slate-400 dark:text-slate-500 shrink-0">{category.skills.length}</span>
                </div>
                <!-- Skill badges -->
                <ul class="space-y-2">
                  {category.skills.map((skill) => (
                      <li class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg
                                  bg-slate-100 dark:bg-slate-700/60
                                  border border-slate-200 dark:border-slate-600
                                  border-l-2 border-l-slate-300 dark:border-l-slate-500
                                  hover:border-primary-400 dark:hover:border-primary-500
                                  hover:border-l-primary-400 dark:hover:border-l-primary-500
                                  hover:text-primary-600 dark:hover:text-primary-400
                                  hover:-translate-y-0.5 hover:shadow-sm
                                  transition-all duration-150 cursor-default">
                        <span class="text-xs font-medium text-slate-700 dark:text-slate-300 leading-tight">
                          {skill}
                        </span>
                      </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Soft Skills -->
    <div class="mb-12">
      <h3 class="text-2xl font-bold mb-8 text-center text-slate-700 dark:text-slate-200 reveal">
        {t('skills.soft')}
      </h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {softSkillCategories.map((cat, i) => (
          <div class="reveal h-full" style={`--reveal-delay: ${i * 100}ms`}>
            <div class="skill-card group bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-xl transition-all duration-300 rounded-2xl overflow-hidden h-full">
              <!-- Gradient top accent strip -->
              <div class={`h-[3px] w-full bg-gradient-to-r ${cat.gradient}`}></div>
              <div class="p-5 h-full hover:-translate-y-1 transition-transform duration-300">
                <div class="flex items-center gap-3 mb-4 pb-3 border-b border-slate-100 dark:border-slate-700/60">
                  <div class={`w-11 h-11 rounded-xl bg-gradient-to-br ${cat.iconGradient} flex items-center justify-center text-xl flex-shrink-0`}>
                    {cat.icon}
                  </div>
                  <h4 class="font-bold text-base text-slate-800 dark:text-slate-100">{t(cat.categoryKey)}</h4>
                  <span class="ml-auto text-xs font-medium text-slate-400 dark:text-slate-500 shrink-0">{cat.skills.length}</span>
                </div>
                <div class="flex flex-wrap gap-2">
                  {cat.skills.map(({ key, emoji }) => (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-full bg-violet-500/10 text-violet-600 dark:text-violet-400 border border-violet-500/20 hover:bg-violet-500/20 hover:-translate-y-0.5 hover:shadow-sm transition-all duration-200 cursor-default">
                      <span class="leading-none">{emoji}</span>
                      {t(key)}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Languages -->
    <div>
      <h3 class="text-2xl font-bold mb-8 text-center text-slate-700 dark:text-slate-200 reveal">
        {t('skills.languages')}
      </h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="reveal">
          <div class="skill-card group bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-xl transition-all duration-300 rounded-2xl overflow-hidden">
            <!-- Gradient top accent strip -->
            <div class="h-[3px] w-full bg-gradient-to-r from-primary-500 to-accent-500"></div>
            <div class="p-5 h-full hover:-translate-y-1 transition-transform duration-300">
              <div class="flex items-center gap-3 mb-4 pb-3 border-b border-slate-100 dark:border-slate-700/60">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-xl flex-shrink-0">
                  {languageCategory.icon}
                </div>
                <h4 class="font-bold text-base text-slate-800 dark:text-slate-100">{t(languageCategory.categoryKey)}</h4>
                <span class="ml-auto text-xs font-medium text-slate-400 dark:text-slate-500 shrink-0">{languageCategory.skills.length}</span>
              </div>
              <ul class="space-y-2">
                {languageCategory.skills.map(({ key, badge }) => (
                  <li class="flex items-center justify-between gap-2 px-2.5 py-1.5 rounded-lg
                              bg-slate-100 dark:bg-slate-700/60
                              border border-slate-200 dark:border-slate-600
                              border-l-2 border-l-slate-300 dark:border-l-slate-500
                              hover:border-primary-400 dark:hover:border-primary-500
                              hover:border-l-primary-400 dark:hover:border-l-primary-500
                              hover:-translate-y-0.5 hover:shadow-sm
                              transition-all duration-150 cursor-default">
                    <span class="text-xs font-medium text-slate-700 dark:text-slate-300">
                      {t(key)}
                    </span>
                    <span class="px-2 py-0.5 rounded-full text-[10px] font-bold tracking-wide
                                  bg-primary-500 dark:bg-primary-400 text-white dark:text-slate-900 shrink-0">
                      {badge}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
