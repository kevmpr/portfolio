---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isEs = lang === 'es';

// Soft skills per language
const softSkills = isEs
  ? [
      { emoji: '🤝', label: 'Trabajo en Equipo' },
      { emoji: '🧩', label: 'Resolución de Problemas' },
      { emoji: '🗣️', label: 'Comunicación' },
      { emoji: '📋', label: 'Organización' },
      { emoji: '🚀', label: 'Aprendizaje Continuo' },
      { emoji: '🌐', label: 'Adaptabilidad' },
      { emoji: '🎯', label: 'Negociación' },
      { emoji: '✅', label: 'Ética Profesional' },
    ]
  : [
      { emoji: '🤝', label: 'Teamwork' },
      { emoji: '🧩', label: 'Problem Solving' },
      { emoji: '🗣️', label: 'Communication' },
      { emoji: '📋', label: 'Organization' },
      { emoji: '🚀', label: 'Continuous Learning' },
      { emoji: '🌐', label: 'Adaptability' },
      { emoji: '🎯', label: 'Negotiation' },
      { emoji: '✅', label: 'Professional Ethics' },
    ];
---

<section id="skills" class="relative py-20 lg:py-28" style="content-visibility: auto; contain-intrinsic-size: auto 600px;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent">
          {t('skills.title')}
        </span>
      </h2>
      <p class="text-center text-slate-500 dark:text-slate-400 mt-3 max-w-2xl mx-auto text-base">
        {t('skills.description')}
      </p>
    </div>

    <!-- Categories -->
    <div class="grid grid-cols-1 gap-10">

      <!-- Cloud -->
      <div class="flex items-start gap-6 lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-8 reveal">
        <div class="w-40 lg:w-48 shrink-0 pt-2">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">Cloud</span>
        </div>
        <div class="flex flex-wrap gap-3">
          <!-- Devicon skills -->
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-azure-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Azure</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-docker-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Docker</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-terraform-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Terraform</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-linux-plain text-xl w-6 h-6 flex items-center justify-center text-slate-700 dark:text-slate-200"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Linux</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-bash-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Bash</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-git-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Git</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-github-original text-xl w-6 h-6 flex items-center justify-center dark:invert"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">GitHub</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-vscode-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">VS Code</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-postman-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Postman</span>
          </div>
          <!-- Pill-only skills (no devicon) -->
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            PowerShell
          </div>
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            ARM Templates
          </div>
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            IaC
          </div>
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            RBAC
          </div>
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            FinOps
          </div>
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            Azure DevOps
          </div>
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            VMs & VNets
          </div>
          <div class="flex items-center px-3 py-2 rounded-xl bg-primary-500/10 dark:bg-primary-500/10 border border-primary-200 dark:border-primary-800/50 text-sm font-medium text-primary-700 dark:text-primary-300 hover:shadow-md transition-all duration-200">
            Networking
          </div>
        </div>
      </div>

      <!-- Frontend -->
      <div class="flex items-start gap-6 lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-8 reveal">
        <div class="w-40 lg:w-48 shrink-0 pt-2">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">Frontend</span>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-html5-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">HTML5</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-css3-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">CSS3</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-javascript-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">JavaScript</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-typescript-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">TypeScript</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-angularjs-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Angular</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-tailwindcss-original colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Tailwind CSS</span>
          </div>
        </div>
      </div>

      <!-- Backend -->
      <div class="flex items-start gap-6 lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-8 reveal">
        <div class="w-40 lg:w-48 shrink-0 pt-2">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">Backend</span>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-nodejs-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Node.js</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-express-original text-xl w-6 h-6 flex items-center justify-center dark:invert"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Express</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-java-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Java</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-spring-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Spring</span>
          </div>
        </div>
      </div>

      <!-- Databases -->
      <div class="flex items-start gap-6 lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-8 reveal">
        <div class="w-40 lg:w-48 shrink-0 pt-2">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">
            {isEs ? 'Bases de Datos' : 'Databases'}
          </span>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-postgresql-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">PostgreSQL</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200 group">
            <i class="devicon-mysql-plain colored text-xl w-6 h-6 flex items-center justify-center"></i>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">MySQL</span>
          </div>
        </div>
      </div>

      <!-- Soft Skills -->
      <div class="flex items-start gap-6 lg:gap-12 border-b border-slate-100 dark:border-slate-800 pb-8 reveal">
        <div class="w-40 lg:w-48 shrink-0 pt-2">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">Soft Skills</span>
        </div>
        <div class="flex flex-wrap gap-3">
          {softSkills.map(({ emoji, label }) => (
            <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-violet-50 dark:bg-violet-900/20 border border-violet-200 dark:border-violet-700/40 text-sm font-medium text-violet-700 dark:text-violet-300 hover:shadow-md transition-all duration-200">
              <span>{emoji}</span>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Languages -->
      <div class="flex items-start gap-6 lg:gap-12 reveal">
        <div class="w-40 lg:w-48 shrink-0 pt-2">
          <span class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight uppercase">
            {isEs ? 'Idiomas' : 'Languages'}
          </span>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 text-sm font-medium text-slate-700 dark:text-slate-200 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200">
            🇪🇸 Español — Nativo
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 text-sm font-medium text-slate-700 dark:text-slate-200 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-md transition-all duration-200">
            🇬🇧 English — B2
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
