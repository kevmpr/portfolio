      </div>

    </div>

    <!-- ── Life Changelog ── -->
    <div class="mt-20 reveal">
      <!-- Divider -->
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px flex-1 bg-slate-200 dark:bg-slate-700"></div>
        <span class="text-xs font-mono font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em]">{t('about.changelog')}</span>
        <div class="h-px flex-1 bg-slate-200 dark:bg-slate-700"></div>
      </div>

      <!-- 4-column grid — most recent on the left -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

        <!-- Mar 2026 — UADE -->
        <div class="group p-5 rounded-2xl bg-white dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-md transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-2 h-2 rounded-full bg-primary-500 ring-2 ring-primary-100 dark:ring-primary-900/50"></div>
            <span class="font-mono text-xs font-bold text-primary-500">Mar 2026</span>
          </div>
          <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">{t('changelog.uade')}</p>
          <p class="text-xs text-slate-400 dark:text-slate-500">UADE · Buenos Aires</p>
        </div>

        <!-- Oct 2025 — Azure Cloud Engineer -->
        <div class="group p-5 rounded-2xl bg-white dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 hover:border-emerald-300 dark:hover:border-emerald-700 hover:shadow-md transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <div class="relative w-2 h-2">
              <div class="absolute inset-0 rounded-full bg-emerald-400 animate-ping opacity-60"></div>
              <div class="relative w-2 h-2 rounded-full bg-emerald-500 ring-2 ring-emerald-100 dark:ring-emerald-900/50"></div>
            </div>
            <span class="font-mono text-xs font-bold text-emerald-500">Oct 2025</span>
          </div>
          <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">{t('changelog.azure')}</p>
          <p class="text-xs text-slate-400 dark:text-slate-500">Readymind · AZ-104 · AZ-700</p>
        </div>

        <!-- May 2025 — Cloud Engineer -->
        <div class="group p-5 rounded-2xl bg-white dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 hover:border-accent-300 dark:hover:border-accent-700 hover:shadow-md transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-2 h-2 rounded-full bg-accent-400 ring-2 ring-accent-100 dark:ring-accent-900/50"></div>
            <span class="font-mono text-xs font-bold text-accent-500">May 2025</span>
          </div>
          <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">{t('changelog.cloud')}</p>
          <p class="text-xs text-slate-400 dark:text-slate-500">Readymind · AZ-900 · DP-900</p>
