              </div>
              <div class="mt-4">
                <p class="text-xs text-slate-400 dark:text-slate-500 font-medium mb-2">{t('about.techused')}</p>
                <div class="flex flex-wrap gap-1.5">
                  {azureTechTags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-accent-500/10 text-accent-600 dark:text-accent-400 border border-accent-500/20">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Cloud Engineer — previous -->
          <div class="relative reveal" style="--reveal-delay:150ms">
            <div class="tl-dot absolute -left-10 top-5 w-4 h-4 rounded-full bg-accent-400 ring-2 ring-white dark:ring-slate-900 z-10" style="box-shadow:0 0 0 4px rgba(6,182,212,0.1),0 0 8px rgba(6,182,212,0.25);"></div>
            <div class="bg-white/80 dark:bg-slate-800/70 backdrop-blur-sm border border-slate-200 dark:border-slate-700 rounded-2xl p-5 hover:border-accent-400 dark:hover:border-accent-500 hover:shadow-lg transition-all duration-300">
              <div class="flex items-start justify-between gap-3 mb-3">
                <div class="flex items-start gap-3 min-w-0">
                  <div class="shrink-0 w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-purple-700 flex items-center justify-center">
                    <span class="text-white text-sm font-bold">RM</span>
