  </div>
</section>

<script>
  function positionTimelineLines() {
    document.querySelectorAll<HTMLElement>('.tl-container').forEach(container => {
      const dots = Array.from(container.querySelectorAll<HTMLElement>('.tl-dot'));
      const line = container.querySelector<HTMLElement>('.tl-line');
      if (dots.length < 2 || !line) return;

      // offsetTop walks up the offsetParent chain — NOT affected by CSS transforms
      function offsetRelativeTo(el: HTMLElement, ancestor: HTMLElement): number {
        let top = 0;
        let cur: HTMLElement | null = el;
        while (cur && cur !== ancestor) {
          top += cur.offsetTop;
          cur = cur.offsetParent as HTMLElement | null;
        }
        return top;
      }

      const first = dots[0];
      const last  = dots[dots.length - 1];

      const firstCenter = offsetRelativeTo(first, container) + first.offsetHeight / 2;
      const lastCenter  = offsetRelativeTo(last,  container) + last.offsetHeight  / 2;

      line.style.top    = `${firstCenter}px`;
      line.style.height = `${lastCenter - firstCenter}px`;
      line.style.bottom = 'auto';
      line.style.opacity = '1';
    });
  }

  document.fonts.ready.then(() => {
    positionTimelineLines();
    const ro = new ResizeObserver(positionTimelineLines);
    document.querySelectorAll<HTMLElement>('.tl-container').forEach(c => ro.observe(c));
  });
</script>
