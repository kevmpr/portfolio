                  <div class="min-w-0">
                    <h4 class="text-base font-bold text-slate-900 dark:text-white leading-snug">{t('exp.azure.title')}</h4>
                    <p class="text-accent-600 dark:text-accent-400 font-medium text-sm mt-0.5">{t('exp.azure.company')}</p>
