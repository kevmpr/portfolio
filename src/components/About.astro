                </div>
              </div>
              <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">{t('edu.uade.description')}</p>
            </div>
          </div>

          <!-- IFTS -->
          <div class="relative reveal" style="--reveal-delay:150ms">
