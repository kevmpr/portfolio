                    <span class="text-white text-sm font-bold">IF</span>
                  </div>
                  <div class="min-w-0">
                    <h4 class="text-base font-bold text-slate-900 dark:text-white leading-snug">{t('edu.ifts.title')}</h4>
                    <p class="text-primary-600 dark:text-primary-400 font-medium text-sm mt-0.5">{t('edu.ifts.institution')}</p>
                  </div>
                </div>
                <div class="flex flex-col items-end gap-1.5 shrink-0">
                  <span class="text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">{t('edu.ifts.period')}</span>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-600 whitespace-nowrap">{t('edu.ifts.status')}</span>
