                  <div class="min-w-0">
                    <h4 class="text-base font-bold text-slate-900 dark:text-white leading-snug">{t('exp.cloud.title')}</h4>
                    <p class="text-accent-600 dark:text-accent-400 font-medium text-sm mt-0.5">{t('exp.cloud.company')}</p>
                  </div>
                </div>
                <div class="flex flex-col items-end gap-1.5 shrink-0">
                  <span class="text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">{t('exp.cloud.period')}</span>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-600 whitespace-nowrap">{t('exp.cloud.location')}</span>
                </div>
              </div>
              <div class="space-y-2">
                {t('exp.cloud.description').split('\n').map((p) => (
                  <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">{p}</p>
                ))}
              </div>
              <div class="mt-4">
                <p class="text-xs text-slate-400 dark:text-slate-500 font-medium mb-2">{t('about.techused')}</p>
                <div class="flex flex-wrap gap-1.5">
                  {cloudTechTags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-accent-500/10 text-accent-600 dark:text-accent-400 border border-accent-500/20">{tag}</span>
                  ))}
