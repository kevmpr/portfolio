---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isEs = lang === 'es';

const navLinks = [
  { key: 'nav.home',     anchor: '#hero' },
  { key: 'nav.about',    anchor: '#about' },
  { key: 'nav.projects', anchor: '#projects' },
  { key: 'nav.skills',   anchor: '#skills' },
  { key: 'nav.contact',  anchor: '#contact' },
] as const;
---

<footer class="border-t border-slate-100 dark:border-slate-800">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-10">

    <div class="flex flex-col md:flex-row items-center justify-between gap-8">

      <!-- Left: name + tagline -->
      <div class="flex items-center gap-3">
        <div class="w-6 h-0.5 bg-primary-500"></div>
        <span class="text-sm font-bold text-slate-900 dark:text-white tracking-tight">Kevin Palma</span>
      </div>

      <!-- Center: nav links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center items-center gap-x-1 gap-y-2">
          {navLinks.map((link, i) => (
            <>
              <li>
                <a
                  href={link.anchor}
                  class="text-xs font-medium text-slate-400 dark:text-slate-500 hover:text-primary-500 dark:hover:text-primary-400 transition-colors duration-200 px-1.5 py-0.5"
                >
                  {t(link.key)}
                </a>
              </li>
              {i < navLinks.length - 1 && (
                <li aria-hidden="true" class="text-slate-200 dark:text-slate-700 select-none text-xs">·</li>
              )}
            </>
          ))}
        </ul>
      </nav>

      <!-- Right: social + copyright -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/kevin-m-palma-r/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-slate-400 dark:text-slate-500 hover:text-primary-500 dark:hover:text-primary-400 transition-colors duration-200"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="https://github.com/kevmpr"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-slate-400 dark:text-slate-500 hover:text-primary-500 dark:hover:text-primary-400 transition-colors duration-200"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>

        <span class="text-slate-200 dark:text-slate-700 text-xs" aria-hidden="true">·</span>

        <span class="text-xs text-slate-400 dark:text-slate-500">
          &copy; {new Date().getFullYear()} Kevin Palma
        </span>
      </div>

    </div>

  </div>
</footer>
