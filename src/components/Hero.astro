---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import imgProfile from '../assets/imgProfile.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEs = lang === 'es';
---

<section id="home" class="relative min-h-screen flex items-center bg-white dark:bg-slate-900 overflow-hidden">
  <!-- Subtle dot texture -->
  <div class="absolute inset-0 bg-dot-pattern opacity-20 dark:opacity-10 pointer-events-none" aria-hidden="true"></div>
  <!-- Very soft ambient glow -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary-400/5 dark:bg-primary-500/8 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-6 sm:px-8 lg:px-16 w-full py-28 lg:py-0 min-h-screen flex items-center">
    <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-20 w-full">

      <!-- ── Left: Text ── -->
      <div class="flex-1 min-w-0 text-center lg:text-left">

        <!-- Accent line -->
        <div class="w-10 h-0.5 bg-primary-500 mb-6 mx-auto lg:mx-0"></div>

        <!-- Heading -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-4 text-slate-900 dark:text-white">
          {isEs ? 'Hola, soy' : "Hi, I'm"}<br/>
          Kevin Palma.
        </h1>

        <!-- Role badge -->
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 mb-5">
          <div class="relative w-1.5 h-1.5">
            <div class="absolute inset-0 rounded-full bg-emerald-400 animate-ping opacity-75"></div>
            <div class="relative w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
          </div>
          <span class="text-slate-600 dark:text-slate-300 font-medium text-xs">{t('hero.role')} @ Readymind</span>
        </div>

        <!-- Bio -->
        <p class="text-slate-500 dark:text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
          {t('hero.bio')}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
          <a
            href="#contact"
            class="group inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg bg-primary-600 hover:bg-primary-500 text-white font-semibold shadow-md shadow-primary-600/20 hover:shadow-primary-500/30 transition-[transform,box-shadow,background-color] duration-300 hover:-translate-y-0.5 text-sm"
            aria-label="Go to contact section"
          >
            {t('hero.contact')}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={`/cv/${lang}/CV Kevin Maximiliano Palma Romero - Azure Cloud Engineer 2026.pdf`}
            download
            class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 font-semibold hover:border-slate-300 dark:hover:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all duration-300 hover:-translate-y-0.5 text-sm"
            aria-label="Download CV"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            {t('hero.cta')}
          </a>
        </div>


      </div>

      <!-- ── Right: Photo ── -->
      <div class="flex-shrink-0" id="photo-perspective" style="perspective:1200px;">
        <div id="photo-tilt" style="transition:transform 0.12s ease-out;transform-style:preserve-3d;">
          <div class="w-60 h-60 sm:w-72 sm:h-72 lg:w-80 lg:h-80 xl:w-96 xl:h-96 rounded-full overflow-hidden ring-4 ring-slate-100 dark:ring-slate-800 bg-slate-200 dark:bg-slate-800">
            <Image
              src={imgProfile}
              alt="Kevin Maximiliano Palma Romero"
              width={400}
              height={400}
              format="webp"
              quality={85}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const perspective = document.getElementById('photo-perspective');
  const tilt = document.getElementById('photo-tilt');

  if (perspective && tilt) {
    let rafId: number | null = null;
    window.addEventListener('mousemove', (e) => {
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight / 2;
      const tx = (e.clientX - cx) / cx;
      const ty = (e.clientY - cy) / cy;
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = null;
        tilt.style.transform = `rotateX(${-ty * 6}deg) rotateY(${tx * 6}deg)`;
      });
    }, { passive: true });
    document.addEventListener('mouseleave', () => {
      tilt.style.transform = '';
    });
  }
</script>
