---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import imgProfile from '../assets/imgProfile.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="home" class="relative min-h-screen overflow-hidden">
  <div class="flex flex-col lg:flex-row min-h-screen">

    <!-- ── Left Panel ── -->
    <div class="relative flex-1 flex flex-col justify-center px-8 sm:px-12 lg:px-14 xl:px-24 pt-28 pb-14 bg-white dark:bg-slate-950">
      <!-- Subtle dot texture -->
      <div class="absolute inset-0 bg-dot-pattern opacity-30 pointer-events-none" aria-hidden="true"></div>

      <div class="relative max-w-xl">

        <!-- Name — oversized split -->
        <h1 class="text-6xl sm:text-7xl xl:text-8xl font-extrabold leading-[0.88] mb-6 tracking-tight">
          <span class="block text-slate-900 dark:text-white">Kevin</span>
          <span class="block text-primary-600 dark:text-primary-400">Palma<span class="text-slate-300 dark:text-slate-600">.</span></span>
        </h1>

        <!-- Status badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 mb-5">
          <div class="relative w-2 h-2">
            <div class="absolute inset-0 rounded-full bg-emerald-400 animate-ping opacity-75"></div>
            <div class="relative w-2 h-2 rounded-full bg-emerald-500"></div>
          </div>
          <span class="text-slate-600 dark:text-slate-300 font-semibold text-sm">{t('hero.role')} @ Readymind</span>
        </div>

        <!-- Tagline -->
        <p class="text-lg sm:text-xl font-semibold text-slate-600 dark:text-slate-300 mb-4 leading-snug">
          {t('hero.tagline')}
        </p>

        <!-- Bio -->
        <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-8 max-w-md">
          {t('hero.bio')}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="#contact"
            class="group inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-xl bg-primary-600 hover:bg-primary-500 text-white font-semibold shadow-lg shadow-primary-600/25 hover:shadow-primary-500/35 transition-[transform,box-shadow,background-color] duration-300 hover:-translate-y-0.5"
            aria-label="Go to contact section"
          >
            {t('hero.contact')}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={`/cv/${lang}/CV Kevin Maximiliano Palma Romero - Azure Cloud Engineer 2026.pdf`}
            download
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 font-semibold hover:border-slate-300 dark:hover:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-800/60 transition-[transform,box-shadow,border-color,background-color] duration-300 hover:-translate-y-0.5"
            aria-label="Download CV"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            {t('hero.cta')}
          </a>
        </div>

        <!-- Stats row -->
        <div class="flex gap-10 mt-10 pt-8 border-t border-slate-100 dark:border-slate-800/80">
          <div>
            <p class="text-3xl font-black text-slate-900 dark:text-white tabular-nums leading-none">{t('hero.stat1.value')}</p>
            <p class="text-xs text-slate-400 dark:text-slate-500 mt-1 leading-snug max-w-[80px]">{t('hero.stat1.label')}</p>
          </div>
          <div>
            <p class="text-3xl font-black text-slate-900 dark:text-white tabular-nums leading-none">{t('hero.stat2.value')}</p>
            <p class="text-xs text-slate-400 dark:text-slate-500 mt-1 leading-snug max-w-[80px]">{t('hero.stat2.label')}</p>
          </div>
          <div>
            <p class="text-3xl font-black text-slate-900 dark:text-white tabular-nums leading-none">{t('hero.stat3.value')}</p>
            <p class="text-xs text-slate-400 dark:text-slate-500 mt-1 leading-snug max-w-[80px]">{t('hero.stat3.label')}</p>
          </div>
        </div>

      </div>
    </div>

    <!-- ── Right Panel — Azure Blue ── -->
    <div class="relative flex w-full lg:w-[42%] xl:w-[44%] min-h-[55vw] lg:min-h-screen items-center justify-center bg-primary-600 dark:bg-primary-700 overflow-hidden">

      <!-- Decorative geometry -->
      <div class="absolute top-16 left-10 w-3 h-3 rotate-45 bg-white/15" aria-hidden="true"></div>
      <div class="absolute top-32 right-24 w-2 h-2 rounded-full bg-white/15" aria-hidden="true"></div>
      <div class="absolute bottom-28 left-20 w-2 h-2 rotate-45 bg-white/10" aria-hidden="true"></div>
      <div class="absolute bottom-48 right-14 w-3 h-3 rounded-full bg-white/10" aria-hidden="true"></div>
      <!-- Large subtle circle behind photo -->
      <div class="absolute w-[500px] h-[500px] rounded-full border border-white/8 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
      <div class="absolute w-[380px] h-[380px] rounded-full border border-white/5 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>

      <!-- Photo with mouse parallax -->
      <div id="photo-perspective" class="relative z-10" style="perspective:1200px;">
        <div id="photo-tilt" style="transition:transform 0.12s ease-out;transform-style:preserve-3d;">
          <div class="relative inline-flex items-center justify-center">
            <!-- White spinning ring — pops on blue bg -->
            <div
              class="absolute -inset-[4px] rounded-full"
              style="background:conic-gradient(from 0deg,rgba(255,255,255,0.85),rgba(255,255,255,0.15),rgba(255,255,255,0.85));animation:border-spin 8s linear infinite;will-change:transform;"
              aria-hidden="true"
            ></div>
            <!-- Gap ring matching panel bg -->
            <div class="absolute -inset-[2px] rounded-full bg-primary-600 dark:bg-primary-700" aria-hidden="true"></div>
            <!-- Photo -->
            <div class="relative w-56 h-56 sm:w-64 sm:h-64 lg:w-72 lg:h-72 xl:w-80 xl:h-80 rounded-full overflow-hidden">
              <Image
                src={imgProfile}
                alt="Kevin Maximiliano Palma Romero"
                width={384}
                height={384}
                format="webp"
                quality={80}
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Vertical "AZURE CLOUD" — right edge -->
      <div class="absolute right-5 top-1/2 -translate-y-1/2 hidden lg:flex flex-col items-center gap-3" aria-hidden="true">
        <div class="w-px h-14 bg-white/20"></div>
        <span class="text-white/35 text-[9px] font-bold tracking-[0.3em] uppercase" style="writing-mode:vertical-rl;text-orientation:mixed;">AZURE CLOUD</span>
        <div class="w-px h-14 bg-white/20"></div>
      </div>

    </div>

  </div>
</section>

<script>
  const perspective = document.getElementById('photo-perspective');
  const tilt = document.getElementById('photo-tilt');

  if (perspective && tilt) {
    let rafId: number | null = null;

    window.addEventListener('mousemove', (e) => {
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight / 2;
      const tx = (e.clientX - cx) / cx;
      const ty = (e.clientY - cy) / cy;
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = null;
        tilt.style.transform = `rotateX(${-ty * 7}deg) rotateY(${tx * 7}deg)`;
      });
    }, { passive: true });

    document.addEventListener('mouseleave', () => {
      tilt.style.transform = '';
    });
  }
</script>

<style>
  @keyframes border-spin {
    0%   { transform: rotate(0deg);   }
    100% { transform: rotate(360deg); }
  }
</style>
