---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import imgProfile from '../assets/imgProfile.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="home" class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
  <!-- Very subtle background — let global Layout blobs do the heavy lifting -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 bg-dot-pattern opacity-30"></div>
    <div class="absolute -top-48 -right-48 w-[480px] h-[480px] bg-primary-400/10 dark:bg-primary-500/8 rounded-full blur-3xl animate-float" style="will-change:transform;"></div>
    <div class="absolute -bottom-48 -left-48 w-[400px] h-[400px] bg-accent-400/8 dark:bg-accent-500/6 rounded-full blur-3xl animate-float-delayed" style="will-change:transform;"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-20">

      <!-- ── Text Content ── -->
      <div class="flex-1 text-center lg:text-left">

        <!-- Name -->
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold mb-4 leading-tight tracking-tight">
          <span class="bg-gradient-to-br from-slate-900 to-primary-700 dark:from-white dark:to-primary-300 bg-clip-text text-transparent">
            {t('hero.name')}
          </span>
        </h1>

        <!-- Tagline — the positioning statement -->
        <p class="text-xl sm:text-2xl font-semibold text-slate-600 dark:text-slate-300 mb-6 leading-snug max-w-xl mx-auto lg:mx-0">
          {t('hero.tagline')}
        </p>

        <!-- Status badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm border border-slate-200 dark:border-slate-700 shadow-sm mb-6">
          <div class="relative w-2 h-2">
            <div class="absolute inset-0 rounded-full bg-emerald-400 animate-ping opacity-75"></div>
            <div class="relative w-2 h-2 rounded-full bg-emerald-500"></div>
          </div>
          <span class="text-slate-700 dark:text-slate-200 font-semibold text-sm">
            {t('hero.role')} @ Readymind
          </span>
        </div>

        <!-- Bio -->
        <p class="text-slate-500 dark:text-slate-400 text-base leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          {t('hero.bio')}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="#contact"
            class="group inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl bg-primary-600 hover:bg-primary-500 text-white font-semibold shadow-lg shadow-primary-600/25 hover:shadow-primary-500/35 transition-[transform,box-shadow,background-color] duration-300 hover:-translate-y-0.5"
            aria-label="Go to contact section"
          >
            {t('hero.contact')}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={`/cv/${lang}/CV Kevin Maximiliano Palma Romero - Azure Cloud Engineer 2026.pdf`}
            download
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 font-semibold hover:border-slate-300 dark:hover:border-slate-600 hover:shadow-md transition-[transform,box-shadow,border-color] duration-300 hover:-translate-y-0.5"
            aria-label="Download CV as PDF"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            {t('hero.cta')}
          </a>
        </div>
      </div>

      <!-- ── Profile Photo with Mouse Parallax ── -->
      <div class="flex-shrink-0" id="photo-perspective" style="perspective:1200px;">
        <div id="photo-tilt" style="transition:transform 0.12s ease-out;transform-style:preserve-3d;">
          <div class="relative inline-flex items-center justify-center">
            <!-- Azure-blue spinning ring -->
            <div
              class="absolute -inset-[4px] rounded-full"
              style="background:conic-gradient(from 0deg,#0078D4,#38bdf8,#50e6ff,#0078D4);animation:border-spin 8s linear infinite;will-change:transform;"
              aria-hidden="true"
            ></div>
            <!-- White gap ring -->
            <div class="absolute -inset-[2px] rounded-full bg-white dark:bg-slate-900" aria-hidden="true"></div>
            <!-- Photo -->
            <div class="relative w-64 h-64 sm:w-72 sm:h-72 lg:w-80 lg:h-80 rounded-full overflow-hidden bg-slate-200 dark:bg-slate-800">
              <Image
                src={imgProfile}
                alt="Kevin Maximiliano Palma Romero"
                width={384}
                height={384}
                format="webp"
                quality={80}
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Mouse parallax on hero photo
  const perspective = document.getElementById('photo-perspective');
  const tilt = document.getElementById('photo-tilt');

  if (perspective && tilt) {
    let rafId: number | null = null;
    let targetX = 0;
    let targetY = 0;

    window.addEventListener('mousemove', (e) => {
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight / 2;
      targetX = (e.clientX - cx) / cx; // -1 to 1
      targetY = (e.clientY - cy) / cy;

      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = null;
        tilt.style.transform = `rotateX(${-targetY * 7}deg) rotateY(${targetX * 7}deg)`;
      });
    }, { passive: true });

    document.addEventListener('mouseleave', () => {
      tilt.style.transform = '';
    });
  }
</script>

<style>
  @keyframes border-spin {
    0%   { transform: rotate(0deg);   }
    100% { transform: rotate(360deg); }
  }
</style>
