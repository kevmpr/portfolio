---
interface Props {
  title: string;
  challenge: string;
  solution: string;
  tech: string[];
  icon: string;
  challengeLabel: string;
  solutionLabel: string;
  stackLabel: string;
  impact: string;
  impactLabel: string;
}

const {
  title,
  challenge,
  solution,
  tech,
  icon,
  challengeLabel,
  solutionLabel,
  stackLabel,
  impact,
  impactLabel,
} = Astro.props;

const icons: Record<string, { viewBox: string; path: string }> = {
  shield: {
    viewBox: '0 0 24 24',
    path: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
  search: {
    viewBox: '0 0 24 24',
    path: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  migrate: {
    viewBox: '0 0 24 24',
    path: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
  },
  cost: {
    viewBox: '0 0 24 24',
    path: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  document: {
    viewBox: '0 0 24 24',
    path: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
};

const selectedIcon = icons[icon] || icons.shield;
---

<div class="bg-white dark:bg-slate-800/80 border border-slate-200/80 dark:border-slate-700/50 rounded-2xl overflow-hidden hover:border-slate-300 dark:hover:border-slate-600 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">

  <!-- Top section -->
  <div class="p-6 flex flex-col flex-grow">

    <!-- Header row: icon + title -->
    <div class="flex items-start gap-4">
      <div class="w-12 h-12 rounded-xl bg-primary-500/10 dark:bg-primary-500/15 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox={selectedIcon.viewBox}>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={selectedIcon.path}></path>
        </svg>
      </div>
      <h3 class="text-base font-bold text-slate-900 dark:text-white leading-snug pt-1">{title}</h3>
    </div>

    <!-- Challenge -->
    <div class="mt-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-400 dark:text-slate-500 mb-1">{challengeLabel}</p>
      <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{challenge}</p>
    </div>

    <!-- Solution -->
    <div class="mt-3 flex-grow">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-400 dark:text-slate-500 mb-1">{solutionLabel}</p>
      <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{solution}</p>
    </div>

  </div>

  <!-- Impact block -->
  <div class="mx-6 mb-6 p-4 rounded-xl bg-gradient-to-r from-primary-50 to-accent-50/50 dark:from-primary-900/20 dark:to-accent-900/20 border border-primary-100 dark:border-primary-800/30">
    <div class="flex items-start gap-2">
      <svg class="w-4 h-4 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
      </svg>
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-primary-600 dark:text-primary-400 mb-0.5">{impactLabel}</p>
        <p class="text-sm font-semibold text-slate-700 dark:text-slate-200">{impact}</p>
      </div>
    </div>
  </div>

  <!-- Footer: tech badges -->
  <div class="px-6 pb-5 flex flex-wrap gap-1.5">
    {tech.map((item) => (
      <span class="text-xs px-2.5 py-1 rounded-lg bg-slate-100 dark:bg-slate-700/60 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-600/50">
        {item}
      </span>
    ))}
  </div>

</div>
