---
interface Props {
  title: string;
  challenge: string;
  solution: string;
  tech: string[];
  icon: string;
  challengeLabel: string;
  solutionLabel: string;
  stackLabel: string;
  impact: string;
  impactLabel: string;
}

const {
  title,
  challenge,
  solution,
  tech,
  icon,
  challengeLabel,
  solutionLabel,
  stackLabel,
  impact,
  impactLabel,
} = Astro.props;

const icons: Record<string, { viewBox: string; path: string }> = {
  shield: {
    viewBox: '0 0 24 24',
    path: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
  search: {
    viewBox: '0 0 24 24',
    path: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  migrate: {
    viewBox: '0 0 24 24',
    path: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
  },
  cost: {
    viewBox: '0 0 24 24',
    path: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  document: {
    viewBox: '0 0 24 24',
    path: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
};

const selectedIcon = icons[icon] || icons.shield;
---

<div class="group flex flex-col h-full border border-slate-100 dark:border-slate-800 rounded-2xl p-6 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:border-slate-200 dark:hover:border-slate-700 hover:shadow-lg hover:shadow-slate-200/60 dark:hover:shadow-slate-900/40 hover:-translate-y-0.5 transition-all duration-300">

  <!-- Header: icon + title -->
  <div class="flex items-start gap-4 mb-5">
    <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0 group-hover:bg-primary-50 dark:group-hover:bg-primary-900/20 group-hover:scale-110 transition-all duration-300">
      <svg class="text-slate-500 dark:text-slate-400 group-hover:text-primary-500 transition-colors duration-300" style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox={selectedIcon.viewBox}>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={selectedIcon.path}></path>
      </svg>
    </div>
    <h3 class="text-sm font-bold text-slate-900 dark:text-white leading-snug pt-1.5">{title}</h3>
  </div>

  <!-- Challenge -->
  <div class="mb-3">
    <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-1.5">{challengeLabel}</p>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{challenge}</p>
  </div>

  <!-- Solution -->
  <div class="flex-1 mb-5">
    <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-1.5">{solutionLabel}</p>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{solution}</p>
  </div>

  <!-- Impact: left border accent -->
  <div class="border-l-2 border-primary-500 pl-4 py-0.5 mb-5">
    <p class="text-xs font-bold uppercase tracking-widest text-primary-500 mb-0.5">{impactLabel}</p>
    <p class="text-sm font-semibold text-slate-700 dark:text-slate-200">{impact}</p>
  </div>

  <!-- Tech tags -->
  <div class="flex flex-wrap gap-1.5">
    {tech.map((item) => (
      <span class="text-xs px-2.5 py-1 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400">
        {item}
      </span>
    ))}
  </div>

</div>
