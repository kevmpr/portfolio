---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="relative py-24 lg:py-32 overflow-hidden" style="content-visibility: auto; contain-intrinsic-size: auto 600px;">
  <!-- Background decoration blobs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-32 -left-32 w-[500px] h-[500px] bg-primary-500/5 dark:bg-primary-500/5 rounded-full blur-3xl" style="will-change: transform, opacity;"></div>
    <div class="absolute -bottom-32 -right-32 w-[500px] h-[500px] bg-accent-500/5 dark:bg-accent-500/5 rounded-full blur-3xl" style="will-change: transform, opacity;"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Part 1: CTA Hero Block -->
    <div class="text-center mb-16">
      <!-- Large heading -->
      <h2 class="text-5xl md:text-6xl font-extrabold text-slate-900 dark:text-white mb-4 leading-tight">
        {t('contact.heading')}
      </h2>

      <!-- Gradient subtitle -->
      <p class="text-2xl md:text-3xl font-semibold bg-gradient-to-r from-primary-500 to-accent-500 bg-clip-text text-transparent mb-5">
        {t('contact.subheading')}
      </p>

      <!-- Description -->
      <p class="text-slate-600 dark:text-slate-400 text-lg max-w-xl mx-auto mb-10">
        {t('contact.description')}
      </p>

      <!-- Primary CTA button -->
      <a
        href="mailto:kev.mpr03@outlook.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-gradient-to-r from-primary-600 to-accent-500 hover:from-primary-500 hover:to-accent-400 text-white font-semibold text-lg shadow-lg shadow-primary-500/25 hover:shadow-primary-500/40 transition-[transform,box-shadow,background-image] duration-300 hover:-translate-y-0.5"
        aria-label="Send email"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        {t('contact.cta')}
      </a>
    </div>

    <!-- Part 2: Contact cards row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto">

      <!-- Email card -->
      <a
        href="mailto:kev.mpr03@outlook.com"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-5 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-lg hover:shadow-primary-500/10 transition-[border-color,box-shadow] duration-300"
        aria-label="Send email"
      >
        <div class="shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-rose-400 to-red-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-bold text-slate-800 dark:text-slate-100 text-sm">{t('contact.email')}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400 truncate">{t('contact.emailSubtitle')}</p>
        </div>
      </a>

      <!-- LinkedIn card -->
      <a
        href="https://www.linkedin.com/in/kevin-m-palma-r/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-5 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-lg hover:shadow-primary-500/10 transition-[border-color,box-shadow] duration-300"
        aria-label="Open LinkedIn profile"
      >
        <div class="shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-bold text-slate-800 dark:text-slate-100 text-sm">{t('contact.linkedin')}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400 truncate">{t('contact.linkedinSubtitle')}</p>
        </div>
      </a>

      <!-- GitHub card -->
      <a
        href="https://github.com/kevmpr"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-5 hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-lg hover:shadow-primary-500/10 transition-[border-color,box-shadow] duration-300"
        aria-label="Open GitHub profile"
      >
        <div class="shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-slate-600 to-slate-900 dark:from-slate-400 dark:to-slate-600 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-bold text-slate-800 dark:text-slate-100 text-sm">{t('contact.github')}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400 truncate">{t('contact.githubSubtitle')}</p>
        </div>
      </a>

    </div>
  </div>
</section>
